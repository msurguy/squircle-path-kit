{
  "name": "@msurguy/squircle-path-kit",
  "version": "1.0.0",
  "description": "Figma-exact SVG squircle paths — corner rounding + corner smoothing for rectangles and arbitrary polygons, verified against Figma's own output within 0.01px.",
  "keywords": [
    "squircle",
    "figma",
    "corner-smoothing",
    "border-radius",
    "svg",
    "path",
    "rounded-corners",
    "superellipse",
    "ios"
  ],
  "license": "MIT",
  "author": "Maks Surguy",
  "repository": {
    "type": "git",
    "url": "https://github.com/msurguy/squircle-path-kit.git"
  },
  "homepage": "https://msurguy.github.io/squircle-path-kit/",
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./dist/index.js",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "require": "./dist/index.cjs"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "sideEffects": false,
  "scripts": {
    "build:lib": "tsup src/index.ts --format esm,cjs --dts --clean",
    "build:site": "vite build --config site/vite.config.ts",
    "build": "npm run build:lib && npm run build:site",
    "dev": "vite --config site/vite.config.ts --host 127.0.0.1",
    "preview": "vite preview --config site/vite.config.ts --host 127.0.0.1",
    "test": "npm run build:lib && node --test test/*.test.js",
    "pack:check": "npm pack --dry-run --cache ./.npm-cache",
    "prepublishOnly": "npm test"
  },
  "devDependencies": {
    "@types/react": "^18.3.0",
    "@types/react-dom": "^18.3.0",
    "@vitejs/plugin-react": "^6.0.3",
    "lucide-react": "^0.468.0",
    "react": "^18.3.0",
    "react-dom": "^18.3.0",
    "tsup": "^8.0.0",
    "typescript": "^5.4.0",
    "vite": "^8.1.3"
  },
  "overrides": {
    "esbuild": "^0.28.1"
  }
}
